{
  "schema_version": 1,
  "quilt_loader": {
    "group": "${group}",
    "id": "examplemod",
    "version": "${version}",
    "metadata": {
      "name": "Territorial",
      "description": "A very chaotic mod",
      "contributors": {
        "Sleepy Evelyn": "Sleepy Evelyn"
      },
      "contact": {
        "homepage": "https://sylv.gay/projects/vulpixel/",
        "issues": "https://github.com/VulpixelMC/Territorial/issues",
        "sources": "https://github.com/VulpixelMC/Territorial"
      },
      "icon": "assets/examplemod/icon.png",
      "license": "MIT"
    },
    "intermediate_mappings": "net.fabricmc:intermediary",
    "entrypoints": {
      "init": "net.examplemod.quilt.ExampleModQuilt"
    },
    "depends": [
      {
        "id": "quilt_loader",
        "version": "*"
      },
      {
        "id": "quilt_base",
        "version": "*"
      },
      {
        "id": "minecraft",
        "version": ">=1.20.1"
      },
      {
        "id": "architectury",
        "version": ">=9.1.12"
      }
    ]
  },
  "mixin": [
    "examplemod.mixins.json"
  ]
}